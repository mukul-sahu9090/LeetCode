class Solution {
public:
    int maxArea(vector<int>& height) {
        int area=0;
        int maxarea=INT_MIN;
        int lp=0;
        int rp=height.size()-1;
        while(lp<rp){
            int width=rp-lp;
            int length=min(height[lp],height[rp]);
            area=width*length;
            maxarea=max(maxarea,area);
            if(height[lp]<height[rp]){
                lp++;
            }else {
                rp--;
            }

        }
        return maxarea;
    }
        
};
