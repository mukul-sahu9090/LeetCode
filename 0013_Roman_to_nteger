class Solution(object):
    def romanToInt(self, s):
        value={
            "I":1,
            "V":5,
            "X":10,
            "L":50,
            "C":100,
            "D":500,
            "M":1000
        }
        number=0
        str=len(s)-1
        for i in range (str):
            if(value[s[i]]>=value[s[i+1]]):
                number = number + value[s[i]]
            else:
                number=number-value[s[i]]
        count=number+value[s[str]]
        return count
